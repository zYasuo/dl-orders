generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/users-client"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("user_profiles")
}
