{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:orders": "nest build orders",
    "build:inventory": "nest build inventory",
    "build:product": "nest build product",
    "build:notification": "nest build notification",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:orders": "nest start orders",
    "start:inventory": "nest start inventory",
    "start:product": "nest start product",
    "start:notification": "nest start notification",
    "start:dev:orders": "nest start orders --watch",
    "start:dev:inventory": "nest start inventory --watch",
    "start:dev:product": "nest start product --watch",
    "start:dev:notification": "nest start notification --watch",
    "start:debug:orders": "nest start orders --debug --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:orders:generate": "prisma generate --schema=apps/orders/prisma/schema.prisma",
    "prisma:orders:push": "cd apps/orders/prisma && prisma db push",
    "prisma:orders:migrate": "cd apps/orders/prisma && prisma migrate dev",
    "prisma:inventory:generate": "prisma generate --schema=apps/inventory/prisma/schema.prisma",
    "prisma:inventory:push": "cd apps/inventory/prisma && prisma db push",
    "prisma:inventory:migrate": "cd apps/inventory/prisma && prisma migrate dev",
    "prisma:product:generate": "prisma generate --schema=apps/product/prisma/schema.prisma",
    "prisma:product:push": "cd apps/product/prisma && prisma db push",
    "prisma:product:migrate": "cd apps/product/prisma && prisma migrate dev",
    "prisma:notification:generate": "prisma generate --schema=apps/notification/prisma/schema.prisma",
    "prisma:notification:push": "cd apps/notification/prisma && prisma db push",
    "prisma:notification:migrate": "cd apps/notification/prisma && prisma migrate dev",
    "prisma:generate:all": "npm run prisma:orders:generate && npm run prisma:inventory:generate && npm run prisma:product:generate && npm run prisma:notification:generate"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "dotenv": "^16.4.5",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    },
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
