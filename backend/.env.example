# Write (primary): writes, transactions, migrations. Prisma migrate uses DATABASE_URL.
# Prefer DATABASE_WRITE_URL for clarity; app config falls back to DATABASE_URL if unset.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dl_orders
DATABASE_WRITE_URL=postgresql://postgres:postgres@localhost:5432/dl_orders

# Read (replica, optional). When set, read queries use this; otherwise they use write URL.
# Docker: postgres-read is on port 5433. Without streaming replication, run migrations on both DBs in dev or sync schema manually.
DATABASE_READ_URL=postgresql://postgres:postgres@localhost:5433/dl_orders

# RabbitMQ (defaults shown)
RABBITMQ_URL=amqp://admin:admin@localhost:5672
QUEUE_NAME=orders_queue

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Notificações <onboarding@resend.dev>
